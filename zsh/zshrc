plugins=(
   git
   docker
   docker-compose
   z
   extract
)

ZSH_THEME=leite

# pin the compinit cache to a fixed path so macOS hostname drift
# (wallpants-287, etc.) doesn't litter $HOME with .zcompdump files
export ZSH_COMPDUMP="$HOME/.cache/zsh/.zcompdump-$ZSH_VERSION"
mkdir -p "$HOME/.cache/zsh"

source ~/.oh-my-zsh/oh-my-zsh.sh

export EDITOR="nvim"
export VISUAL="nvim"

# pnpm
export PNPM_HOME="$HOME/.pnpm-home"
export PATH="$PNPM_HOME:$PATH"

export GOPATH="$HOME/.go"
export PATH="$GOPATH/bin:$PATH"

export BUN_INSTALL=$HOME/.bun
export PATH=$BUN_INSTALL/bin:$PATH

export PATH="$HOME/.local/bin:$PATH"

# vim keymaps
set -o vi

# ALIAS
# alias python="python3.11"
alias vi="nvim"
# plugin-free-ish nvim: core options/keymaps + allowlist in nvim/minimal.lua
alias vim="nvim -u ~/.dotfiles/nvim/minimal.lua"
alias lzg="lazygit"
alias :q="exit"
alias :Q="exit"
alias dotfiles="cd ~/.dotfiles"
alias public="cat ~/.ssh/id_ed25519.pub"
alias ssh="nohup lemonade server > /dev/null 2>&1 &! kitty +kitten ssh -R 2489:127.0.0.1:2489"

## ls aliases
# alias l="ls -1"
# alias la="ls -oAh"

alias l='lsd -A --group-directories-first --oneline'
# alias la='lsd -l --group-directories-first'
alias la='lsd -lA --group-directories-first'

alias condainit='conda init "$(basename "${SHELL}")"'
alias qwen="ANTHROPIC_BASE_URL=http://localhost:1234 ANTHROPIC_AUTH_TOKEN=lmstudio claude --model qwen/qwen3.6-27b"

# remap Ctrl+L to both scroll the current screen contents into the scrollback buffer
# and clear the screen, instead of just clearing the screen
scroll-and-clear-screen() {
    printf '\n%.0s' {1..$LINES}
    zle clear-screen
}
zle -N scroll-and-clear-screen
bindkey '^L' scroll-and-clear-screen
bindkey "^N" down-line-or-beginning-search
bindkey "^P" up-line-or-beginning-search

echo ""
echo ""
echo "Microsoft(R) Windows 95"
echo "   (C)Copyright Microsoft Corp 1981-1996."
echo ""

source ~/.dotfiles/zsh/os_specific.zsh

